# .env.example
# Copiá este archivo como .env y completá con tus credenciales reales.
# NUNCA comprometas .env al repositorio.

# Zona horaria base (por defecto Buenos Aires)
BASE_TIMEZONE=America/Argentina/Buenos_Aires

# Zoom Server-to-Server OAuth — Cuenta 1 (info@)
ZOOM_ACCOUNT_ID=YOUR_ACCOUNT_ID
ZOOM_CLIENT_ID=YOUR_CLIENT_ID
ZOOM_CLIENT_SECRET=YOUR_CLIENT_SECRET
ZOOM_HOST_EMAIL=info@example.com

# Zoom Server-to-Server OAuth — Cuenta 2 (cursos@)
ZOOM2_ACCOUNT_ID=YOUR_ACCOUNT_ID_2
ZOOM2_CLIENT_ID=YOUR_CLIENT_ID_2
ZOOM2_CLIENT_SECRET=YOUR_CLIENT_SECRET_2
ZOOM2_HOST_EMAIL=cursos@example.com

# WordPress / LearnDash
# URL base del sitio (sin slash final), usuario admin y Application Password
WP_BASE_URL=https://tu-sitio.com
WP_USER=admin@example.com
# Nota: WP_APP_PASSWORD puede tener espacios al copiarlo; este sistema los normaliza removiendo espacios
WP_APP_PASSWORD=app-password-aqui

# LearnDash assignment strategy (true|false)
# When true, prefer the ld-automation plugin to add lessons into the Course Builder
# Useful if your site doesn't expose the official course-steps endpoints
USE_LD_PLUGIN=false

# WooCommerce / FluentCRM / TablePress / FluentCommunity
# WooCommerce (requerido si se usa actualización de producto)
WC_CONSUMER_KEY=ck_xxx
WC_CONSUMER_SECRET=cs_xxx
# Modo simulación global (true = no escribe nada en el servidor, false = ejecución real)
# Usá DRY_RUN=true para probar el flujo completo antes de ejecutar en vivo.
DRY_RUN=false

# FluentCRM (Basic Auth hacia el mismo WP_BASE_URL en /wp-json/fluent-crm/v2)
# Usuario con acceso a FluentCRM (puede ser el mismo admin de WP con Application Password)
FLUENTCRM_USER=apiuser
FLUENTCRM_PASS=apipass

# TablePress / FluentCommunity (sin variables por ahora)
